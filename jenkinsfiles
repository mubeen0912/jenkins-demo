pipeline {
    agent any

    environment {
        DOCKER_IMAGE = 'mubeenr7/jenkins-demo:latest'
    }

    stages {
        stage('Build Docker Image') {
            steps {
                sh 'docker build -t $DOCKER_IMAGE .'
            }
        }

        stage('Push to Docker Hub') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'dockerhub-credentials',
                    usernameVariable: 'DOCKER_USERNAME',
                    passwordVariable: 'DOCKER_TOKEN'
                )]) {
                    sh 'echo "$DOCKER_TOKEN" | docker login -u "$DOCKER_USERNAME" --password-stdin'
                    sh 'docker push $DOCKER_IMAGE'
                }
            }
        }

        stage('Deploy to EC2-2') {
    steps {
        sshagent(['ec2-deploy-key']) {
            sh '''
                ssh -o StrictHostKeyChecking=no ubuntu@172.31.23.175 "
                    docker pull mubeenr7/jenkins-demo:latest &&
                    docker rm -f jenkins-demo-container || true &&
                    docker run -d \
                      --name jenkins-demo-container \
                      -p 80:80 \
                      mubeenr7/jenkins-demo:latest
                "
            '''
        }
    }
}
    }
}
